# OpenRAL — example reasoner LLM configurations
#
# Pick ONE of the three blocks below, copy to `.env` (gitignored), and
# `source .env` before `ros2 run openral_reasoner_ros reasoner_node` or
# any sim run that activates the S2 reasoner. `openral doctor` will report
# what's missing if any required variable is unset.
#
# CLAUDE.md §1.4 — the open core has no default LLM. Explicit beats
# implicit; you must pick one here.

# ── Option 1: paid baseline (Anthropic Haiku 4.5) ────────────────────
# Recommended default. ~$1/$5 per Mtok, ~0.74 s TTFT, native tool use.
# One-time: `uv add anthropic --package openral-reasoner`
#
# export OPENRAL_REASONER_LLM_PROVIDER=anthropic
# export OPENRAL_REASONER_LLM_MODEL=claude-haiku-4-5
# export OPENRAL_REASONER_LLM_API_KEY=sk-ant-...

# ── Option 2: free baseline (OpenRouter free models) ─────────────────
# DeepSeek v3 / Llama-4-Maverick / Qwen3-235B all pass tool-calling
# tests. Use `openrouter/free` as the model id for the auto-router.
# One-time: `uv add openai --package openral-reasoner`
#
# export OPENRAL_REASONER_LLM_PROVIDER=openrouter
# export OPENRAL_REASONER_LLM_MODEL=deepseek/deepseek-chat-v3:free
# export OPENRAL_REASONER_LLM_API_KEY=sk-or-...

# ── Option 3: local baseline (Ollama + Qwen3 8B) ─────────────────────
# Setup: `just bootstrap-ollama`
# One-time: `uv add openai --package openral-reasoner`
#
# export OPENRAL_REASONER_LLM_PROVIDER=openai-compatible
# export OPENRAL_REASONER_LLM_MODEL=qwen3:8b
# export OPENRAL_REASONER_LLM_BASE_URL=http://localhost:11434/v1

# ── Named vendor presets (Gemini / xAI / DeepSeek) ───────────────────
# Thin auth-required shortcuts over the OpenAI-compatible client that
# pre-fill the vendor base URL (issue #74). See the table in
# packages/openral_reasoner_ros/README.md.
# One-time: `uv add openai --package openral-reasoner`
#
# export OPENRAL_REASONER_LLM_PROVIDER=gemini    # or: xai / deepseek
# export OPENRAL_REASONER_LLM_MODEL=gemini-2.5-flash
# export OPENRAL_REASONER_LLM_API_KEY=...

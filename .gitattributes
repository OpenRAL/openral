# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for scripts
*.sh text eol=lf
*.bash text eol=lf

# Force LF for Python
*.py text eol=lf

# Force LF for YAML/TOML/JSON
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# C++
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf

# CMake
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# ROS 2 IDL
*.msg text eol=lf
*.srv text eol=lf
*.action text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svg binary
*.pdf binary
*.mp4 binary
*.safetensors binary
*.onnx binary
*.plan binary

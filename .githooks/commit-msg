#!/usr/bin/env bash
# Validate the commit message via the pre-commit framework's commit-msg stage
# (conventional-pre-commit). Committed rather than generated by
# `pre-commit install` for the same reason as .githooks/pre-commit: the repo
# pins core.hooksPath=.githooks for DCO sign-off, and `pre-commit install`
# refuses to run with core.hooksPath set.
#
# Runs after prepare-commit-msg (which appends the DCO Signed-off-by trailer),
# so the trailer is present before the message is validated.
set -euo pipefail

if ! command -v uv >/dev/null 2>&1; then
    echo "[hooks] 'uv' not found on PATH — install uv and run 'just install-hooks'." >&2
    exit 1
fi

exec uv run pre-commit run --hook-stage commit-msg --commit-msg-filename "$1"

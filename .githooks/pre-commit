#!/usr/bin/env bash
# Run the pre-commit framework (.pre-commit-config.yaml) at the pre-commit stage:
# ruff, ruff-format, mypy, codespell, clang-format, and the pre-commit-hooks
# checks. This wrapper is committed (not generated by `pre-commit install`)
# on purpose: the repo pins `core.hooksPath=.githooks` so the DCO sign-off
# prepare-commit-msg hook is active, and `pre-commit install` *refuses* to run
# when core.hooksPath is set ("cowardly refusing"). `just install-hooks`
# pre-builds the hook environments so the first commit is fast.
set -euo pipefail

if ! command -v uv >/dev/null 2>&1; then
    echo "[hooks] 'uv' not found on PATH — install uv and run 'just install-hooks'." >&2
    exit 1
fi

# `pre-commit run` with no file selector runs against the staged files.
exec uv run pre-commit run --hook-stage pre-commit

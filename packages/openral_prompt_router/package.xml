<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>openral_prompt_router</name>
  <version>0.1.0</version>
  <description>
    OpenRAL prompt router (ADR-0018 F10) — single lifecycle node that
    fans in operator prompts from any external source (CLI today;
    dashboard WebSocket / voice / Slack post-v1) into a normalised
    openral_msgs/PromptStamped stream on /openral/prompt. FIFO
    arbitration with source-priority tags; no silent drops.
  </description>
  <maintainer email="contact@openral.dev">OpenRAL Contributors</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>

  <depend>rclpy</depend>
  <depend>lifecycle_msgs</depend>
  <depend>rclpy_lifecycle</depend>
  <depend>openral_msgs</depend>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>ament_cmake_pytest</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>

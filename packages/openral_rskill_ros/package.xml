<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>openral_rskill_ros</name>
  <version>0.1.0</version>
  <description>
    ADR-0018 F1 — rskill_runner_node lifecycle node that owns the
    openral_msgs/ExecuteRskill action server and the in-process
    HardwareRunner. Composes one shared openral_world_state.WorldStateAggregator
    with the world_state lifecycle node (single subscriber of /joint_states
    per ADR-0018 §3) and publishes openral_msgs/ActionChunk on
    /openral/candidate_action via openral_runner.ROSPublishingHAL. One node
    per robot.
  </description>
  <maintainer email="contact@openral.dev">OpenRAL Contributors</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>

  <depend>rclpy</depend>
  <depend>rclpy_lifecycle</depend>
  <depend>lifecycle_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>std_srvs</depend>
  <depend>diagnostic_msgs</depend>
  <depend>openral_msgs</depend>

  <exec_depend>python3-openral-core</exec_depend>
  <exec_depend>python3-openral-world-state</exec_depend>
  <exec_depend>python3-openral-rskill</exec_depend>
  <exec_depend>python3-openral-runner</exec_depend>
  <exec_depend>python3-openral-observability</exec_depend>
  <exec_depend>python3-openral-hal</exec_depend>
  <!-- ADR-0059 — the read-only Foxglove live-scene bridge, spawned into the
       deploy-sim runtime graph by the `openral deploy sim` foxglove flag. -->
  <exec_depend>foxglove_bridge</exec_depend>
  <exec_depend>openral_foxglove_bringup</exec_depend>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
